# ── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
# From Meta Developer dashboard > Your App > WhatsApp > API Setup
WA_PHONE_NUMBER_ID=your_phone_number_id_here
WA_ACCESS_TOKEN=your_permanent_system_user_access_token_here

# A random string you choose — must match what you enter in the Meta webhook settings
WEBHOOK_VERIFY_TOKEN=choose_any_secret_string

# ── Google Calendar (service account) ────────────────────────────────────────
# Paste the entire service account JSON as a single line (use a JSON minifier)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Calendar ID to monitor — find it in Google Calendar > Settings > [Calendar name] > Calendar ID
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# ── Claude AI ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Admin API key ─────────────────────────────────────────────────────────────
# Used to authenticate calls to /customers endpoints
ADMIN_API_KEY=choose_any_secret_string

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── SQLite database path (optional) ──────────────────────────────────────────
# On Railway: set to /data/proclean.db after mounting a volume
# DB_PATH=/data/proclean.db
